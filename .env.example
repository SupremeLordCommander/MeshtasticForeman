# Copy this to .env and fill in your values
# cp .env.example .env

# Serial port of the Meshtastic device (leave blank for auto-detect)
#in windows maybe COM7, in linux maybe /dev/ttyUSB0
MESHTASTIC_PORT=COM7

# MQTT broker connection
ENABLE_MQTT=false
MQTT_BROKER=mqtt.meshtastic.org
MQTT_PORT=1883
MQTT_USER=meshdev
MQTT_PASS=large4cats
# Root topic prefix — matches your regional channel plan
MQTT_ROOT=msh/US/CA/Humboldt/Eureka

# Bot command responder — replies to !ping, !nodes, !status, !help on any channel
# Set to true to enable
BOT_ENABLED=false

# Elevation API for terrain-aware coverage (viewshed) on the map.
# Defaults to the public Open-Elevation service (no key required, may be slow).
# For faster/offline operation, run your own instance: https://github.com/Jorl17/open-elevation
# ELEVATION_API_URL=https://api.open-elevation.com/api/v1/lookup

#API options
API_URI=http://localhost
API_HOST=0.0.0.0
API_PORT=3172

#Frontend options
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3173

# Map tile style URL (MapLibre GL style JSON)
# Default: https://tiles.openfreemap.org/styles/liberty
# Override if that tile server is blocked on your network:
# VITE_MAP_STYLE=https://tiles.openfreemap.org/styles/liberty
